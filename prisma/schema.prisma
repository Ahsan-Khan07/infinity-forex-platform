generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//// =========================
//// USER ROLES
//// =========================
enum Role {
  STUDENT
  ADMIN
  USER
  MENTOR
}

//// =========================
//// USER STATUS (SECURITY CONTROL)
//// =========================
enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

//// =========================
//// LOGIN STATUS ENUM
//// =========================
enum LoginStatus {
  SUCCESS
  FAILED
  LOCKED
  TWO_FA_REQUIRED
  NEW_DEVICE
}

//// =========================
//// USER MODEL (CORE IDENTITY)
//// =========================
model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name     String
  email    String @unique
  password String

  role   Role       @default(STUDENT)
  status UserStatus @default(ACTIVE)

  avatarUrl String?

  //// SECURITY SYSTEM
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  lastFailedLogin     DateTime?
  lastLoginAt         DateTime?

  //// 2FA SYSTEM
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  backupCodes      String[]

  isVerified Boolean @default(false)

  resetToken        String?
  verifyToken       String?
  verifyTokenExpiry DateTime?

  //// SESSION SECURITY CORE
  sessionVersion Int @default(0)

  createdAt DateTime @default(now())
}

//// =========================
//// RATE LIMIT SYSTEM
//// =========================
model RateLimit {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// =========================
//// TRUSTED DEVICE SYSTEM
//// =========================
model TrustedDevice {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId      String @db.ObjectId
  fingerprint String

  userAgent String
  ip        String

  isTrusted Boolean @default(false)
  trustScore Int @default(0)

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([userId, fingerprint])
  @@index([userId])
}

//// =========================
//// LOGIN AUDIT LOG
//// =========================
model LoginLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  email  String
  userId String? @db.ObjectId

  ip          String
  userAgent   String
  fingerprint String?

  status LoginStatus
  reason String?

  metadata String?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([ip])
}

//// =========================
//// DEVICE VERIFICATION FLOW
//// =========================
model PendingDeviceLogin {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String? @db.ObjectId
  email  String

  token String @unique

  ip          String?
  userAgent   String?
  fingerprint String?

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([email])
}

//// =========================
//// AUDIT LOG (ENTERPRISE)
//// =========================
model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String? @db.ObjectId

  action String

  ip        String?
  userAgent String?

  metadata String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

//// =========================
//// SESSION TRACKING
//// =========================
model Session {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId

  token String @unique

  ip        String
  userAgent String

  createdAt DateTime @default(now())
  expiresAt DateTime

  revoked Boolean @default(false)

  @@index([userId])
}
