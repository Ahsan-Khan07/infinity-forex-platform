generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//// =========================
//// ENUMS
//// =========================

enum Role {
  STUDENT
  ADMIN
  USER
  MENTOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum LoginStatus {
  SUCCESS
  FAILED
  LOCKED
  TWO_FA_REQUIRED
  NEW_DEVICE
}

//// =========================
//// USER (CORE IDENTITY)
//// =========================

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name     String
  email    String @unique
  password String

  role   Role       @default(STUDENT)
  status UserStatus @default(ACTIVE)

  avatarUrl String?

  //// SECURITY
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  lastFailedLogin     DateTime?
  lastLoginAt         DateTime?

  isVerified Boolean @default(false)

  //// EMAIL / RESET TOKENS
  resetToken        String?
  verifyToken       String?
  verifyTokenExpiry DateTime?

  //// MFA (PRODUCTION GRADE)
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String? // encrypted base32 secret
  mfaSetupRequired Boolean  @default(false)
  mfaBackupCodes   String[] @default([])

  //// DEVICE SECURITY
  lastLoginFingerprint String?
  lastLoginIp          String?

  //// SESSION SECURITY
  sessionVersion Int @default(0)

  //// RELATIONS
  loginHistory        LoginHistory[]
  sessions            Session[]
  trustedDevices      TrustedDevice[]
  auditLogs           AuditLog[]
  loginLogs           LoginLog[]
  pendingDeviceLogins PendingDeviceLogin[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([role])
  @@index([status])
}

//// =========================
//// RATE LIMIT
//// =========================

model RateLimit {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  count     Int      @default(0)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// =========================
//// TRUSTED DEVICES
//// =========================

model TrustedDevice {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fingerprint String
  userAgent   String
  ip          String

  isTrusted  Boolean @default(false)
  trustScore Int     @default(0)

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([userId, fingerprint])
  @@index([userId])
}

//// =========================
//// LOGIN LOGS (SECURITY AUDIT)
//// =========================

model LoginLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  email  String
  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ip          String
  userAgent   String
  fingerprint String?

  status LoginStatus
  reason String?

  metadata String?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([ip])
  @@index([userId])
}

//// =========================
//// PENDING DEVICE LOGIN
//// =========================

model PendingDeviceLogin {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email String

  token String @unique

  ip          String?
  userAgent   String?
  fingerprint String?

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([email])
}

//// =========================
//// AUDIT LOG
//// =========================

model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action String

  ip        String?
  userAgent String?

  metadata Json

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

//// =========================
//// SESSION TRACKING
//// =========================

model Session {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token String @unique

  ip        String
  userAgent String

  createdAt DateTime @default(now())
  expiresAt DateTime

  revoked Boolean @default(false)

  @@index([userId])
}

//// =========================
//// LOGIN HISTORY (USER VIEW)
//// =========================

model LoginHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ip          String?
  fingerprint String?
  userAgent   String?
  device      String?
  location    String?

  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PasswordHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  hash      String
  createdAt DateTime @default(now())
}
